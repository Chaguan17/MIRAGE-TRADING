# ═══════════════════════════════════════════════════════════
# MIRAGE-TRADING — .gitignore
# ═══════════════════════════════════════════════════════════

# ── Secrets ──────────────────────────────────────────────
.env
*.env.local

# ── Python ───────────────────────────────────────────────
__pycache__/
*.py[cod]
*.pyo
.venv/
venv/
*.egg-info/
dist/
build/

# ── Runtime data ─────────────────────────────────────────
backend/storage/
backend/logs/
*.pkl
trade_history.csv

# ── Node ─────────────────────────────────────────────────
node_modules/

# ── IDE ──────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Testing ──────────────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/

# ── OS ───────────────────────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Docker ───────────────────────────────────────────────
*.log